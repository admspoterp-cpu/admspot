<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Visibilidade de pacotes (Android 11+): necessário para o Capacitor Share
      encontrar apps (Gmail, Drive, WhatsApp, etc.) ao compartilhar o PDF do comprovante.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND_MULTIPLE" />
            <data android:mimeType="*/*" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="false">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Rede -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Câmera: leitura de QR Code PIX e linha digitável de boleto (getUserMedia / Quagga) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Feedback tátil (@capacitor/haptics) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Biometria: impressão digital / reconhecimento facial (BiometricPrompt) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!--
      Galeria / mídia: envio de foto da cobrança no dashboard (input file image/*).
      Android 13+ (API 33): permissões granulares de mídia.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Vídeo só se no futuro aceitar vídeo no mesmo fluxo; omitido por ora. -->

    <!--
      Android 12 e anteriores: acesso a imagens na galeria.
      maxSdkVersion evita conflito com READ_MEDIA_* no API 33+.
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Câmera não é obrigatória para instalar o app (ex.: tablet sem câmera) -->
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />
</manifest>
